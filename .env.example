# Your own open model server. Ollama's OpenAI-compatible URL normally ends in /v1.
MODEL_BASE_URL=http://localhost:11434/v1
MODEL_NAME=usman-ai
MODEL_API_KEY=ollama
MODEL_SUPPORTS_VISION=true
MODEL_TIMEOUT_MS=180000
MAX_OUTPUT_TOKENS=1800
MODEL_TEMPERATURE=0.7

APP_NAME=Usman Independent AI
APP_TAGLINE=Your self-hosted AI workspace
PORT=3000

MAX_FILE_MB=100
MAX_FILES=8
MAX_CONTEXT_CHARS=120000
CHAT_REQUESTS_PER_MINUTE=8
MEDIA_REQUESTS_PER_MINUTE=3
ENABLE_DOCUMENT_OCR=false

# Optional: your own Stable Diffusion WebUI API server.
# Leave blank to disable AI image generation and AI image editing.
IMAGE_SERVER_BASE_URL=
IMAGE_SERVER_API_KEY=
IMAGE_TIMEOUT_MS=300000
