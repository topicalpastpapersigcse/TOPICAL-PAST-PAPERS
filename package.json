    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "helmet": "latest",
    "multer": "latest",
    "openai": "latest",
    "pdf-lib": "latest",
    "sharp": "latest"
  }
}
